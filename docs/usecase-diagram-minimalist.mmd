flowchart LR
  %% Actors
  SU[System User]
  ITA[IT Administrator]
  SMO[System Monitoring Operator]
  MT[Maintenance Technician]
  TC[Telemetry Collector]
  AI[AI Analytics Service]
  NS[Notification System]

  %% Actor generalization
  ITA -->|generalize| SU
  SMO -->|generalize| SU
  MT -->|generalize| SU

  %% System boundary
  subgraph SYS[AR-Based Infrastructure Monitoring and Maintenance System]
    %% Access and governance
    U01((Authenticate User))
    U02((End User Session))
    U03((Govern User Access))
    U04((Review Audit Trail))

    %% Platform setup
    U05((Register Simulation Node))
    U06((Map Marker to Asset))
    U07((Configure Alert Rule))

    %% Monitoring and analytics
    U08((Monitor Infrastructure Health))
    U09((Observe Realtime Dashboard))
    U10((Inspect Asset Health Details))
    U11((Review Historical Telemetry))
    U12((Detect AI Anomaly))
    U13((Score Asset Health Risk))

    %% Incident and ticket workflow
    U14((Coordinate Alert Response))
    U15((Review Alert Queue))
    U16((Open Incident Record))
    U17((Dispatch Maintenance Ticket))
    U18((Send Operational Notification))

    %% AR field workflow
    U19((Conduct AR Inspection))
    U20((Identify Asset from Marker))
    U21((Review AR Diagnostics))
    U22((Submit AR Inspection Result))

    %% Simulation
    U23((Run Simulation Scenario))
    U24((Inject Simulation Fault))

    %% System-side data flows
    U25((Stream Node Telemetry))
    U26((Stream Container Metadata))
  end

